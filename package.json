{
  "name": "legacy-resonance-identity",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SVG-first deterministic identity engine for Legacy Sound Design.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run build:identity && npm run build:site",
    "build:identity": "tsc -p tsconfig.json",
    "build:site": "tsc -p tsconfig.site.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "npm run build:identity && node --test dist/tests/*.test.js",
    "export": "npm run build:identity && node dist/scripts/export-assets.js",
    "verify": "npm run test && npm run export && npm run build:site"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "opentype.js": "^2.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
